    "import sqlite3\n",
    "import pandas as pd\n",
    "\n",
    "conn = sqlite3.connect(\"../database/unicorns.db\")\n",
    "\n",
    "df = pd.read_sql(\n",
    "    \"SELECT * FROM unicorn_companies\",\n",
    "    conn\n",
    ")\n",
    "\n",
    "df.head()"
   ]
